#  KRONOS · Variables de Entorno (Plantilla)
#  Copia este archivo a .env y rellena los valores para desarrollo local.
#  NUNCA subas el archivo .env real a Git.
#  En producción, estas variables se configuran en los dashboards de Koyeb y Vercel.
# ============================================================================

# ============ SERVER ============
# Puerto para el servidor en desarrollo. En producción (Koyeb) se asigna automáticamente.
PORT=5000
NODE_ENV=development

# URL del frontend. Usada por CORS para permitir peticiones.
# En producción (Koyeb) DEBE ser tu dominio de Vercel (ej. https://kronos-app.vercel.app)
CLIENT_URL=http://localhost:3000

# URL pública del backend. Usada por callbacks de OAuth y otras integraciones.
# En producción (Koyeb) será tu URL de Koyeb (ej. https://kronos-api-tu-org.koyeb.app)
SERVER_URL=http://localhost:5000

# ============ BASE DE DATOS ============
# Connection string de tu base de datos MongoDB Atlas.
MONGODB_URI=mongodb+srv://TU_USUARIO:TU_PASSWORD@TU_CLUSTER.mongodb.net/kronos?retryWrites=true&w=majority

# Redis (opcional). Si no se define, el cache cae a memoria (no persistente).
# ============ CACHE (Opcional) ============
# URL de tu instancia de Redis (ej. de Upstash). Si se deja vacía, se usa cache en memoria.
REDIS_URL=

# ============ AUTENTICACIÓN ============
# Genera un secreto largo y aleatorio. Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=SECRETO_JWT_LARGO_Y_ALEATORIO
JWT_EXPIRE=7d

# Clave para el endpoint de sembrado de datos (/api/admin/seed). Pon otra clave aleatoria.
SEED_SECRET=

# ============ SERVICIOS EXTERNOS ============

# --- Cloudinary (almacenamiento de imágenes y videos) ---
# Obtener de tu dashboard de Cloudinary.
CLOUDINARY_CLOUD_NAME=TU_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=TU_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=TU_CLOUDINARY_API_SECRET

# --- Email (Nodemailer con Gmail) ---
# Para enviar correos. Usa una "App Password" de tu cuenta de Google.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false # Es `false` para el puerto 587 (usa STARTTLS)
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASSWORD=TU_APP_PASSWORD_DE_GMAIL_DE_16_LETRAS
EMAIL_FROM=KRONOS <tu-correo@gmail.com>

# ============ Web Push (genera con: npx web-push generate-vapid-keys) ============
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@kronos.app
# --- Web Push Notifications (VAPID) ---
# Genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=TU_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=TU_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@tu-dominio.com

# --- Stripe (procesamiento de pagos) ---
# Obtener de tu dashboard de Stripe (usa las claves de Test para desarrollo).
STRIPE_SECRET_KEY=SK_TEST_DE_STRIPE
STRIPE_WEBHOOK_SECRET=WHSEC_DE_TU_ENDPOINT_DE_WEBHOOK_EN_STRIPE

# --- Price IDs de Stripe para Suscripciones ---
# Crea los productos y planes en tu dashboard de Stripe y pega aquí los IDs de los precios (price_...).
STRIPE_SOCIAL_PREMIUM_PRICE_ID=PRICE_ID_SOCIAL_PREMIUM
STRIPE_SCRIPTS_ESTANDAR_PRICE_ID=PRICE_ID_SCRIPTS_ESTANDAR
STRIPE_SCRIPTS_PREMIUM_PRICE_ID=PRICE_ID_SCRIPTS_PREMIUM
STRIPE_SCRIPTS_PRO_PRICE_ID=PRICE_ID_SCRIPTS_PRO
STRIPE_MEDIA_ESTANDAR_PRICE_ID=PRICE_ID_MEDIA_ESTANDAR
STRIPE_MEDIA_PREMIUM_PRICE_ID=PRICE_ID_MEDIA_PREMIUM
STRIPE_MEDIA_PRO_PRICE_ID=PRICE_ID_MEDIA_PRO

# --- Price IDs (modelo legacy, si aún se usa) ---
STRIPE_PLUS_PRICE_ID=PRICE_ID_LEGACY_PLUS
STRIPE_PRO_PRICE_ID=PRICE_ID_LEGACY_PRO
STRIPE_BUSINESS_PRICE_ID=PRICE_ID_LEGACY_BUSINESS

# --- IA: OpenAI ---
# Obtener de https://platform.openai.com/api-keys
OPENAI_API_KEY=SK-PROJ_DE_OPENAI

# --- IA: DeepL (Traducción) ---
# Obtener de https://www.deepl.com/pro-api (la clave gratuita termina en :fx)
DEEPL_API_KEY=TU_DEEPL_API_KEY:fx

# --- Web3 / Blockchain (Token KRO) ---
# Obtener de https://infura.io/
INFURA_API_KEY=TU_INFURA_API_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/TU_INFURA_API_KEY
# Clave privada de una wallet de DESARROLLO, NUNCA una con fondos reales.
PRIVATE_KEY=0x_TU_CLAVE_PRIVADA_DE_WALLET_DE_DESARROLLO
# Dirección del contrato del token una vez desplegado en la red de Sepolia.
KRONOS_TOKEN_ADDRESS=0x_DIRECCION_DEL_CONTRATO_KRONOS_TOKEN

# ============ LOGIN SOCIAL (OAuth 2.0) ============
# Obtener de Google Cloud Console y Facebook for Developers.
# Si se dejan vacías, los botones de login social no funcionarán.
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET
FACEBOOK_APP_ID=TU_FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=TU_FACEBOOK_APP_SECRET

# ============================================================================
#  VARIABLES PARA EL CLIENTE (FRONTEND)
#  Vercel necesita estas variables con el prefijo REACT_APP_
# ============================================================================

# URL del backend a la que el cliente (React) hará peticiones. DEBE terminar en /api.
# En producción (Vercel) será tu URL de Koyeb (ej. https://kronos-api-tu-org.koyeb.app/api)
REACT_APP_API_URL=http://localhost:5000/api

# URL para la conexión de WebSockets. Es la misma que la API pero SIN /api.
# En producción (Vercel) será tu URL de Koyeb (ej. https://kronos-api-tu-org.koyeb.app)
REACT_APP_SOCKET_URL=http://localhost:5000

# Clave pública de Stripe (segura de exponer en el frontend).
REACT_APP_STRIPE_PUBLIC_KEY=PK_TEST_DE_STRIPE

# Cloudinary (para subidas directas desde el cliente, si se usa).
REACT_APP_CLOUDINARY_CLOUD_NAME=TU_CLOUDINARY_CLOUD_NAME
REACT_APP_CLOUDINARY_UPLOAD_PRESET=NOMBRE_DE_TU_UPLOAD_PRESET_SIN_FIRMA

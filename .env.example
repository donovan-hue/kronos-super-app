# ============ SERVER ============
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kronos

# JWT
JWT_SECRET=cambiame-en-produccion
JWT_EXPIRES=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@kronos.app

# Web Push (genera con: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@kronos.app

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============ CLIENT (prefijo REACT_APP_) ============
REACT_APP_API_URL=http://localhost:5000
REACT_APP_CLOUDINARY_CLOUD_NAME=
REACT_APP_CLOUDINARY_UPLOAD_PRESET=
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_

# ============ IA / OpenAI ============
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-tu_openai_api_key

# ============ Traducción / DeepL ============
# Free tier (500k chars/mes): https://www.deepl.com/pro-api  — la clave free termina en :fx
DEEPL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx

# ============ Web3 / Blockchain (Token KRO) ============
# Infura gratis (100k req/día): https://infura.io/
INFURA_API_KEY=tu_infura_api_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/tu_infura_api_key
# Completar después del deploy del contrato en Sepolia:
KRONOS_TOKEN_ADDRESS=0x_direccion_del_contrato_desplegado

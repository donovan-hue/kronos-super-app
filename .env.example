# ============================================================================
#  KRONOS · variables de entorno (plantilla)
#  Copia este archivo a .env y rellena los valores. NUNCA subas el .env real.
#  En producción se configuran en el dashboard de Render (backend) y Vercel (front).
# ============================================================================

# ============ SERVER ============
PORT=5000
NODE_ENV=development

# CLIENT_URL: origen(es) permitido(s) por CORS. En producción (Render) DEBE ser tu
# dominio EXACTO con https:// y SIN barra final. Acepta varios separados por coma.
# Ej: https://midominio.com,https://www.midominio.com
CLIENT_URL=http://localhost:3000

# SERVER_URL: URL pública del backend. La usan los callbacks de OAuth.
# Producción: https://kronos-api-qq0o.onrender.com
SERVER_URL=http://localhost:5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kronos

# Redis (opcional). Si no se define, el cache cae a memoria (no persistente).
REDIS_URL=

# JWT
JWT_SECRET=cambiame-en-produccion
JWT_EXPIRE=7d

# Clave para sembrar datos vía endpoint admin protegido (POST /api/admin/seed).
SEED_SECRET=

# ============ Cloudinary (multimedia) ============
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============ Email (Nodemailer / Gmail) ============
# El código lee estas variables (no SMTP_*). Para Gmail usa una App Password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=KRONOS <no-reply@kronos.app>

# ============ Web Push (genera con: npx web-push generate-vapid-keys) ============
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@kronos.app

# ============ Stripe ============
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Price IDs · modelo de 3 productos independientes (server/config/subscriptionPlans.js)
# Crea cada Product+Price (mensual) en Stripe y pega aquí el price_xxx.
# Red Social — solo el plan Premium se cobra (lo demás es gratis):
STRIPE_SOCIAL_PREMIUM_PRICE_ID=
# Generador de Scripts (IA):
STRIPE_SCRIPTS_ESTANDAR_PRICE_ID=
STRIPE_SCRIPTS_PREMIUM_PRICE_ID=
STRIPE_SCRIPTS_PRO_PRICE_ID=
# Generador de Videos e Imágenes (IA):
STRIPE_MEDIA_ESTANDAR_PRICE_ID=
STRIPE_MEDIA_PREMIUM_PRICE_ID=
STRIPE_MEDIA_PRO_PRICE_ID=

# ── Price IDs · modelo legacy de 3 tiers (server/services/subscriptionService.js)
STRIPE_PLUS_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# ============ CLIENT (prefijo REACT_APP_) ============
# IMPORTANTE: REACT_APP_API_URL DEBE terminar en /api (el cliente le añade /auth/login, etc.)
# Local:      http://localhost:5000/api
# Producción (Vercel): https://kronos-api-qq0o.onrender.com/api
REACT_APP_API_URL=http://localhost:5000/api
# REACT_APP_SOCKET_URL: el mismo host SIN /api
# Producción (Vercel): https://kronos-api-qq0o.onrender.com
REACT_APP_SOCKET_URL=http://localhost:5000
REACT_APP_CLOUDINARY_CLOUD_NAME=
REACT_APP_CLOUDINARY_UPLOAD_PRESET=
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_

# ============ Login social (OAuth) — opcional ============
# Si se dejan vacías, el login social simplemente queda desactivado.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ============ IA / OpenAI ============
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-tu_openai_api_key

# ============ Traducción / DeepL ============
# Free tier (500k chars/mes): https://www.deepl.com/pro-api  — la clave free termina en :fx
DEEPL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx

# ============ Web3 / Blockchain (Token KRO) ============
# Infura gratis (100k req/día): https://infura.io/
INFURA_API_KEY=tu_infura_api_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/tu_infura_api_key
# Clave privada de la wallet que firma transacciones del token (¡SECRETA!).
PRIVATE_KEY=
# Completar después del deploy del contrato en Sepolia:
KRONOS_TOKEN_ADDRESS=0x_direccion_del_contrato_desplegado

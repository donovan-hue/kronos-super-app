# ============================================================================
#  VARIABLES PARA EL CLIENTE (FRONTEND)
#  Vercel necesita estas variables con el prefijo REACT_APP_
# ============================================================================

# URL del backend a la que el cliente (React) hará peticiones. DEBE terminar en /api.
# En producción (Vercel) será tu URL de Koyeb (ej. https://kronos-api-tu-org.koyeb.app/api)
REACT_APP_API_URL=http://localhost:5000/api

# URL para la conexión de WebSockets. Es la misma que la API pero SIN /api.
# En producción (Vercel) será tu URL de Koyeb (ej. https://kronos-api-tu-org.koyeb.app)
REACT_APP_SOCKET_URL=http://localhost:5000

# Clave pública de Stripe (segura de exponer en el frontend).
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

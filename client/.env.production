# Flags de BUILD para producción (Vercel). NO contiene secretos.
# Create React App los lee al compilar.

# No correr ESLint en el build de producción (lint vive en dev con `npm start`).
# Evita que warnings de hooks aparezcan como alertas en Vercel.
DISABLE_ESLINT_PLUGIN=true

# Warnings no tumban el build.
CI=false

# Sin source maps en prod: build más rápido y bundle más limpio.
GENERATE_SOURCEMAP=false
